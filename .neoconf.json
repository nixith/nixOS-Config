{
  "lspconfig": {
    "nixd": {
      "nixd": {
        "nixpkgs": {
          "expr": "import (import ./npins).nixpkgs { allowUnfree = true; } "
        },
        "formatting": {
          "command": [
            "nixfmt"
          ]
        },
        "options": {
          "nixos": {
            "expr": "(import <nixos-system>).options"
          },
          "home": {
            "expr": "(import <nixos-system>).options.home-manager.users.type.getSubOptions []"
          }
        }
      }
    }
  }
}
